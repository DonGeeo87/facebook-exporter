{
  "manifest_version": 3,
  "name": "Facebook Post Exporter",
  "version": "1.1.0",
  "description": "Exporta posts e imágenes de tus Fanpages de Facebook a JSON/CSV/ZIP. Herramienta para administradores de páginas.",
  "author": "Código Guerrero Dev",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Exportar Posts de Facebook"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*"],
      "js": [
        "jszip.min.js",
        "utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["*.png", "*.jpg", "*.jpeg"],
      "matches": ["https://*.facebook.com/*"]
    }
  ]
}
